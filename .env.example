# ──────────────────────────────────────────────────────────────
# Legado Vivo — variáveis de ambiente
# Copie para `.env` e preencha com os valores reais.
# ──────────────────────────────────────────────────────────────

# Postgres (Railway fornece esta variável automaticamente)
DATABASE_URL="postgresql://usuario:senha@host:5432/railway"

# Claude API (Anthropic) — usada nas Server Actions
ANTHROPIC_API_KEY="sk-ant-..."

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="APP_USR-..."
NEXT_PUBLIC_MERCADO_PAGO_PUBLIC_KEY="APP_USR-..."

# URL pública da aplicação (usada nos redirects do Mercado Pago e no webhook)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
